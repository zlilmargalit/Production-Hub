# Production Hub server config.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── Authentication ──────────────────────────────────────────────────────────
# Username / password that protect the whole site (API + frontend).
# Pick something strong — anyone who knows these gets full access.
AUTH_USER=admin
AUTH_PASSWORD=change-me-please

# ── Optional ────────────────────────────────────────────────────────────────
# Override the bundled Chrome path used by puppeteer-core for PDF generation.
# Defaults to the system Chrome (macOS / Linux). On Railway with the
# `chromium` nix package, set this to the chromium binary path.
# CHROME_PATH=/usr/bin/chromium

# Local-mode: directory to drop generated PDFs into. Leave unset on cloud
# hosts so the PDF is streamed back as a download instead.
# PDF_DIR=/Users/you/Desktop/Production/דפי תיאום

# Google Docs template ID used by the brief creator.
# TEMPLATE_DOC_ID=...

# Express port (defaults to 3001).
# PORT=3001
